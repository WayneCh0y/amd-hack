# Local development only. Copy to `.env` and fill in.
# NEVER commit a real .env or bake it into the Docker image — the judging
# harness injects the real values at evaluation time.
FIREWORKS_API_KEY=your-dev-key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# Comma-separated model IDs. On launch day, use the exact IDs the harness gives.
ALLOWED_MODELS=accounts/fireworks/models/llama-v3p1-8b-instruct,accounts/fireworks/models/llama-v3p3-70b-instruct

# Local-first answering (bundled GGUF via llama-cpp-python). Default: true.
# Set false for native dev on a machine whose llama-cpp-python build doesn't
# match its CPU (e.g. Windows / no-AVX-512) — otherwise loading the model can
# hard-crash the process. In Docker the AVX2 build is correct, so leave it on.
LOCAL_MODEL_ENABLED=false
